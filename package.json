{
  "name": "javascriptseleniumcucumber",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "test:allure": "cucumber-js --format summary --format allure-cucumberjs/reporter",
    "test:allure:headless": "cross-env HEADLESS=true cucumber-js --format summary --format allure-cucumberjs/reporter",
    "allure:generate": "allure generate allure-results --clean  -o allure-report",
    "allure:open": "allure open allure-report"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^13.0.0",
    "allure-commandline": "^2.42.1",
    "allure-cucumberjs": "^3.10.0",
    "chai": "^4.4.1",
    "cross-env": "^10.1.0",
    "csv-parse": "^5.5.6",
    "cucumber-pretty": "^6.0.1",
    "dotenv": "^16.4.5",
    "multiple-cucumber-html-reporter": "^3.8.0",
    "selenium-webdriver": "^4.22.0"
  }
}
